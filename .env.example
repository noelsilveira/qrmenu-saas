# QRMenu SaaS - Production Environment
# Copy this to .env and fill in your values

# APP (REQUIRED - change SECRET_KEY!)
SECRET_KEY=your-64-character-random-secret-key-here-change-immediately

# DATABASE (REQUIRED - change DB_PASSWORD!)
DB_PASSWORD=your-strong-db-password-here

# WHATSAPP (fill before Phase 5)
META_WA_ACCESS_TOKEN=
META_WA_PHONE_NUMBER_ID=
META_WA_BUSINESS_ACCOUNT_ID=
META_WA_WEBHOOK_VERIFY_TOKEN=

# PAYMENTS (fill before Phase 4)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# STORAGE (fill before file uploads)
S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET=qrmenu-assets
S3_ACCESS_KEY=
S3_SECRET_KEY=

# CORS (update when you add a custom domain)
CORS_ORIGINS=["*"]
