# App
APP_NAME=QRMenu SaaS
APP_VERSION=2.0.0
SECRET_KEY=change-me-in-production

# Database
POSTGRES_URI=postgresql+asyncpg://postgres:postgres@localhost:5432/saas_db
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=40

# Redis
REDIS_URI=redis://localhost:6379/0
REDIS_CELERY_URI=redis://localhost:6379/1

# WhatsApp (Meta Business API)
META_WA_API_VERSION=v18.0
META_WA_ACCESS_TOKEN=your_meta_access_token
META_WA_PHONE_NUMBER_ID=your_phone_number_id
META_WA_BUSINESS_ACCOUNT_ID=your_business_account_id
META_WA_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token

# Delivery
OSRM_BASE_URL=http://localhost:5000
GOOGLE_MAPS_API_KEY=your_google_maps_key
MAPBOX_ACCESS_TOKEN=your_mapbox_token

# 3rd Party
TALABAT_API_BASE=https://api.talabat.com/v2
TALABAT_CLIENT_ID=your_talabat_client_id
TALABAT_CLIENT_SECRET=your_talabat_secret
ZOMATO_PARTNER_API_KEY=your_zomato_key
JAHEZ_API_BASE=https://api.jahez.net

# Payments
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Storage
S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET=qrmenu-assets
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key

# Notifications
FIREBASE_CREDENTIALS_JSON_PATH=./firebase-credentials.json
SENDGRID_API_KEY=SG.xxx

# TimescaleDB (Driver tracking)
TIMESCALEDB_URI=postgresql://postgres:postgres@localhost:5433/tracking
